datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model AccessReasonLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model ActionTypeLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)

  transactionItems TransactionItem[]
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Alert {
  alert_id        String             @id @default(uuid())
  device_id       String
  timestamp       DateTime           @default(now()) // Varsayılan değer eklemek iyidir
  alert_type      String
  message         String             @db.VarChar(500)
  status_id       Int
  resolution_note String?            @db.Text 

  device          Cooler             @relation(fields: [device_id], references: [device_id])
  status          AlertStatusLookup  @relation(fields: [status_id], references: [id])

  @@index([device_id])
  @@index([status_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model AlertStatusLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)

  alerts Alert[]
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Brand {
  brand_id    String   @id @default(uuid())
  brand_name  String   @unique @db.VarChar(255)
  description String?  @db.VarChar(255)

  products      Product[]
  productBrands ProductBrand[]
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Cooler {
  device_id             String   @id @default(uuid())
  name                  String   @db.VarChar(100)
  location_description  String?  @db.VarChar(255)
  gps_latitude          Decimal? @db.Decimal(10, 8)
  gps_longitude         Decimal? @db.Decimal(10, 8)
  default_temperature   Decimal? @db.Decimal(2, 2)
  status_id             Int
  last_checkin_time     DateTime
  assigned_admin_id     String?
  door_status           Boolean
  shelf_count           Int
  session_limit         Int

  status        DeviceStatusLookup @relation(fields: [status_id], references: [id])
  assignedAdmin User?              @relation("CoolerAdmin", fields: [assigned_admin_id], references: [user_id])

  inventories       Inventory[]
  coolerProducts    CoolerProduct[]
  transactions      Transaction[]
  telemetries       Telemetry[]
  alerts            Alert[]
  deviceAssignments DeviceAssignment[]

  @@index([assigned_admin_id])
  @@index([status_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model DeviceAssignment {
  assignment_id  String   @id @default(uuid())
  device_id      String
  admin_user_id  String
  assigned_at    DateTime
  unassigned_at  DateTime?
  is_active      Boolean

  device Cooler @relation(fields: [device_id], references: [device_id])
  admin  User   @relation(fields: [admin_user_id], references: [user_id])

  @@index([device_id])
  @@index([admin_user_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model DeviceStatusLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)

  coolers Cooler[]
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model DisputeReasonLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Inventory {
  device_id         String
  product_id        String
  current_stock     Int
  critic_stock      Int
  last_stock_update DateTime

  device  Cooler  @relation(fields: [device_id], references: [device_id])
  product Product @relation(fields: [product_id], references: [product_id])

  @@id([device_id, product_id])
  @@index([product_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Product {
  product_id      String   @id @default(uuid())
  name            String   @unique @db.VarChar(255)
  ai_label        String?  @unique @db.VarChar(255)
  brand_id        String
  unit_price      Decimal  @db.Decimal(10, 2)
  image_reference String?  @db.VarChar(255)
  is_active       Boolean

  brand            Brand            @relation(fields: [brand_id], references: [brand_id])
  inventories      Inventory[]
  coolerProducts   CoolerProduct[]
  transactionItems TransactionItem[]
  productBrands    ProductBrand[]

  @@index([brand_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model CoolerProduct {
  device_id    String
  product_id   String
  is_active    Boolean  @default(true)

  device  Cooler  @relation(fields: [device_id], references: [device_id])
  product Product @relation(fields: [product_id], references: [product_id])

  @@id([device_id, product_id])
  @@index([product_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model ProductBrand {
  product_id String
  brand_id   String

  product Product @relation(fields: [product_id], references: [product_id])
  brand   Brand   @relation(fields: [brand_id], references: [brand_id])

  @@id([product_id, brand_id])
  @@index([brand_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model SystemLog {
  log_id        String   @id @default(uuid())
  title         String   @db.VarChar(255)
  message       String
  level         String   @db.VarChar(50)
  log_date      DateTime @db.Timestamptz
  relational_id String?

  @@index([level])
  @@index([log_date])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Telemetry {
  telemetry_id         String   @id @default(uuid())
  device_id            String
  timestamp            DateTime
  internal_temperature Decimal  @db.Decimal(5, 2)
  gps_latitude         Decimal? @db.Decimal(10, 8)
  gps_longitude        Decimal? @db.Decimal(10, 8)
  door_sensor_status   Boolean

  device Cooler @relation(fields: [device_id], references: [device_id])

  @@index([device_id])
  @@index([timestamp])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model Transaction {
  transaction_id   String   @id @default(uuid())
  user_id          String?
  device_id        String
  start_time       DateTime
  end_time         DateTime?
  is_active        Boolean
  status_id        Int
  transaction_type String?

  user   User?                     @relation(fields: [user_id], references: [user_id])
  device Cooler                    @relation(fields: [device_id], references: [device_id])
  status TransactionStatusLookup   @relation(fields: [status_id], references: [id])

  items TransactionItem[]

  @@index([user_id])
  @@index([device_id])
  @@index([status_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model TransactionItem {
  transaction_item_id String   @id @default(uuid())
  transaction_id      String
  product_id          String
  quantity            Int
  action_type_id      Int
  timestamp           DateTime
  unit_price_at_sale  Decimal  @db.Decimal(10, 2)

  transaction Transaction      @relation(fields: [transaction_id], references: [transaction_id])
  product     Product          @relation(fields: [product_id], references: [product_id])
  actionType  ActionTypeLookup @relation(fields: [action_type_id], references: [id])

  @@index([transaction_id])
  @@index([product_id])
  @@index([action_type_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model TransactionStatusLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)

  transactions Transaction[]
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model User {
  user_id       String    @id @default(uuid())
  first_name    String?   @db.VarChar(100)
  last_name     String?   @db.VarChar(100)
  email         String    @unique @db.VarChar(255)
  password_hash String?   @db.VarChar(255)
  role_id       Int       @default(0)
  active        Boolean?
  created_at    DateTime?
  updated_at    DateTime?

  role              UserRoleLookup      @relation(fields: [role_id], references: [id])
  assignedCoolers   Cooler[]            @relation("CoolerAdmin")
  transactions     Transaction[]
  deviceAssignments DeviceAssignment[]

  @@index([role_id])
}
// Extracted model fragment; Prisma CLI still needs a merged schema.
model UserRoleLookup {
  id   Int    @id
  name String @unique @db.VarChar(50)

  users User[]
}
